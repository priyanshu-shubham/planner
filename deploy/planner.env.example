# planner deployer configuration. Copy to deploy/planner.env and fill in.
#
#   cp deploy/planner.env.example deploy/planner.env
#   $EDITOR deploy/planner.env
#   ./deploy/deploy.sh
#
# deploy/planner.env is gitignored — it holds DB_PASSWORD and any auth secrets.

# --- GCP / Kubernetes -------------------------------------------------------
GCP_PROJECT=some-project
NAMESPACE=planner
SERVICE_NAME=planner
# The deployer applies to the CURRENT kubectl context — select it beforehand
# (kubectl config use-context ...). The script echoes the context for confirmation
# and pauses so you can Ctrl-C if it's wrong.

# --- Artifact Registry / image ----------------------------------------------
AR_REGION=us-central1
AR_REPO=something-docker   # must exist in $AR_REGION and $GCP_PROJECT
IMAGE_NAME=planner
IMAGE_TAG=                 # blank -> current git short sha
# Final image ref: $AR_REGION-docker.pkg.dev/$GCP_PROJECT/$AR_REPO/$IMAGE_NAME:$IMAGE_TAG

# External origin (scheme://host) used for OAuth redirect_uri + Secure cookies +
# setup.md links. If blank, derived from the request Host header, so it "just works" for local
PLANNER_BASE_URL=

# --- Cloud SQL (Postgres) ---------------------------------------------------
CLOUDSQL_INSTANCE=instance-name       # instance name within $GCP_PROJECT
DB_HOST=                   # blank -> auto-derived PRIVATE IP of the instance
DB_NAME=planner
DB_USER=planner
DB_PASSWORD=               # REQUIRED — used to create the user and build the DSN
DB_SSLMODE=require         # require | disable | verify-full (see pgx sslmode docs)

# --- Optional auth (Google login + per-user plan scoping) -------------------
# Leave PLANNER_AUTH=0 (or unset) to run open/single-user. When enabled, the
# server needs a stable HTTPS host with the OAuth redirect
# https://YOUR_HOST/auth/google/callback registered (DNS/TLS is out of scope here).
PLANNER_AUTH=0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PLANNER_AUTH_SECRET=       # pin to a stable secret for durable tokens / >1 replica
